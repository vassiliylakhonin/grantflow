# Copy to .env.enterprise for the shortest enterprise-style evaluation path.
# This profile uses the opinionated compose stack in docker-compose.pilot.yml.

# Required backend secret shared between the gateway and GrantFlow.
GRANTFLOW_API_KEY=change-me-enterprise-key

# Required model provider key.
OPENAI_API_KEY=sk-...

# Optional OpenAI-compatible routing.
# GRANTFLOW_LLM_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://your-eval-host.example
# OPENROUTER_X_TITLE=GrantFlow

# Tenant controls. Keep disabled for a single-team eval.
GRANTFLOW_TENANT_AUTHZ_ENABLED=false
GRANTFLOW_ALLOWED_TENANTS=
GRANTFLOW_DEFAULT_TENANT=

# Optional host port override if you front GrantFlow behind a reverse proxy.
# GRANTFLOW_API_PORT=8000

# Recommended gateway pattern for enterprise-style evaluation:
# - users authenticate at the gateway / reverse proxy
# - gateway injects X-API-Key downstream
# - Redis and Chroma remain private
