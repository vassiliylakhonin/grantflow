# .env.example

# LLM Models
GRANTFLOW_CHEAP_MODEL=gpt-4o-mini
GRANTFLOW_REASONING_MODEL=gpt-4o
GRANTFLOW_MAX_TOKENS=4000
GRANTFLOW_TEMPERATURE=0.7

# Graph Settings
GRANTFLOW_MAX_ITERATIONS=3
GRANTFLOW_CRITIC_THRESHOLD=8.0
GRANTFLOW_HITL_ENABLED=true
GRANTFLOW_RUNTIME_GROUNDED_QUALITY_GATE_MODE=strict
GRANTFLOW_RUNTIME_GROUNDED_QUALITY_GATE_MIN_CITATIONS=5
GRANTFLOW_RUNTIME_GROUNDED_QUALITY_GATE_MAX_NON_RETRIEVAL_CITATION_RATE=0.35
GRANTFLOW_RUNTIME_GROUNDED_QUALITY_GATE_MIN_RETRIEVAL_GROUNDED_CITATIONS=2
GRANTFLOW_EXPORT_REQUIRE_GROUNDED_GATE_PASS=false

# RAG Settings
GRANTFLOW_CHROMA_DIR=./chroma_db
GRANTFLOW_TOP_K=5
# Optional remote Chroma (defaults are intentionally split from API port)
# CHROMA_HOST=127.0.0.1
# CHROMA_PORT=8001

# API Settings
GRANTFLOW_API_HOST=0.0.0.0
GRANTFLOW_API_PORT=8000
GRANTFLOW_DEBUG=false

# Pipeline runner mode (background_tasks | inmemory_queue | redis_queue)
# GRANTFLOW_JOB_RUNNER_MODE=background_tasks
# GRANTFLOW_JOB_RUNNER_WORKER_COUNT=2
# GRANTFLOW_JOB_RUNNER_QUEUE_MAXSIZE=200
# GRANTFLOW_JOB_RUNNER_CONSUMER_ENABLED=true
# GRANTFLOW_JOB_RUNNER_REDIS_URL=redis://127.0.0.1:6379/0
# GRANTFLOW_JOB_RUNNER_REDIS_QUEUE_NAME=grantflow:jobs
# GRANTFLOW_JOB_RUNNER_REDIS_POP_TIMEOUT_SECONDS=1.0

# API Auth (optional; if set, write endpoints require X-API-Key header)
# GRANTFLOW_API_KEY=change-me

# State Persistence (inmem | sqlite)
GRANTFLOW_JOB_STORE=inmem
# Keep GRANTFLOW_HITL_STORE aligned with GRANTFLOW_JOB_STORE.
# Example for sqlite mode:
# GRANTFLOW_HITL_STORE=sqlite
# GRANTFLOW_INGEST_STORE=sqlite
# GRANTFLOW_SQLITE_PATH=./grantflow_state.db

# LLM Provider Keys (раскомментируйте и добавьте свои)
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...
# Optional OpenAI-compatible backend routing (for OpenRouter or proxies)
# GRANTFLOW_LLM_BASE_URL=https://openrouter.ai/api/v1
# Optional OpenRouter headers (recommended when using OpenRouter)
# OPENROUTER_HTTP_REFERER=https://your-app.example
# OPENROUTER_X_TITLE=GrantFlow
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
