# Copy to .env.pilot for the opinionated pilot deployment profile.

# Required shared secrets
GRANTFLOW_API_KEY=change-me-pilot-key
OPENAI_API_KEY=sk-...

# Optional OpenAI-compatible routing
# GRANTFLOW_LLM_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://your-pilot-host.example
# OPENROUTER_X_TITLE=GrantFlow

# Optional tenant gating at the platform layer
GRANTFLOW_TENANT_AUTHZ_ENABLED=false
GRANTFLOW_ALLOWED_TENANTS=
GRANTFLOW_DEFAULT_TENANT=

# Optional pilot host port override if you front this with a reverse proxy
# GRANTFLOW_API_PORT=8000
